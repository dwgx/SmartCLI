# Python build / packaging artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Local dev / test scratch
tools/screenshot/out/
*.tmp
_*_tmp.py

# Coverage run artifacts (config .coveragerc + tools/coverage_run.py + the
# sitecustomize.py hook ARE tracked; only the generated data/reports are not).
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/

# mkdocs site build artifacts. docs/*.md stubs are GENERATED by
# tools/build_docs.py from the canonical sources (README, SKILL.md, etc.), so
# they're not committed — only the real hand-written docs under docs/ are.
# Leading slash anchors to repo root so docs/site/ (the showcase site) is safe.
/site/
docs/index.md
docs/usage.md
docs/skills-cmd-art.md
docs/skills-drive-tui.md
docs/skills-tui-ui.md
docs/knowledge.md
docs/changelog.md

# EXCLUDED FROM PUBLIC RELEASE — reverse-engineered third-party (claude.exe)
# decompiled source + binary string dump. Legal/IP exposure; internal-only.
# See release-conventions memory. Do NOT publish this directory.
research/cc-decompiled/
# dev-only scratch capture frames from effort_selector iteration
research/mine-frames/
research/mine-now/
research/real-frames/
research/_*

# OS noise
Thumbs.db
.DS_Store
